   "metadata": {},
   "source": [
    "### 5. Find the intersection of two sets\n",
    "**Return:** A set containing elements common to both sets"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 39,
   "id": "6a953712",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "{5}"
      ]
     },
     "execution_count": 39,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def set_intersection(s1: set, s2: set) -> set:\n",
    "    return s1.intersection(s2)\n",
    "\n",
    "set_intersection({2,3,4,5},{5,8,9})"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "1b772918",
   "metadata": {},
   "source": [
    "### 6. Count vowels in a string using a for loop\n",
    "**Return:** The number of vowels in the string"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 41,
   "id": "36232be7",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "2"
      ]
     },
     "execution_count": 41,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def count_vowels(s: str) -> int:\n",
    "    vowels='aeiouAEIOU'\n",
    "    num=0\n",
    "    for char in s:\n",
    "        if char in vowels:\n",
    "            num +=1\n",
    "    return num\n",
    "count_vowels (\"rhea\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "768d0ce5",
   "metadata": {},
   "source": [
    "### 7. Categorize temperature (Hot, Warm, Cold)\n",
    "**Return:** 'Hot' if temp > 30, 'Warm' if 15-30, 'Cold' if < 15"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "30b42a5e",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "'warm'"
      ]
     },
     "execution_count": 10,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def categorize_temperature(temp: float) -> str:\n",
    "    if temp>30:\n",
    "        return\"hot\"\n",
    "    if temp<15:\n",
    "        return\"cold\"\n",
    "    else: \n",
    "        return \"warm\"\n",
    "\n",
    "categorize_temperature(25)"
   ]
  },
