   "metadata": {},
   "source": [
    "### 4. Find factorial of a number using a for loop\n",
    "**Return:** The factorial of n (n!)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 36,
   "id": "068ff084",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "120"
      ]
     },
     "execution_count": 36,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def factorial(n: int) -> int:\n",
    "    mahek=1\n",
    "    for i in range (1,n+1):\n",
    "        mahek*=i\n",
    "    return mahek\n",
    "factorial(5)"
   ]
  },
  {
   "cell_type": "markdown",
